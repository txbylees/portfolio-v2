datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth v5 required models ─────────────────────────────────────────────
// Using JWT strategy so no NextAuth Session table is needed.
// This keeps "Session" free for our domain model (recording sessions).

model User {
  id            String               @id @default(cuid())
  name          String?
  email         String               @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  memberships   OrganisationMember[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ────────────────────────────────────────────────────────────

model Organisation {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  members   OrganisationMember[]
  projects  Project[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model OrganisationMember {
  id             String       @id @default(cuid())
  userId         String
  organisationId String
  role           MemberRole   @default(MEMBER)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([userId, organisationId])
  @@index([organisationId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Project {
  id             String       @id @default(cuid())
  name           String
  slug           String
  organisationId String
  webhookUrl     String?
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  apiKeys        ApiKey[]
  sessions       Session[]
  bugs           Bug[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Slugs are unique per org, not globally (like GitHub repos)
  @@unique([organisationId, slug])
  @@index([organisationId])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  // SHA-256 hash of the raw key — raw key is never stored
  keyHash    String    @unique
  // First 12 chars of the raw key for display (e.g. "rpk_ab12cd34ef")
  // Safe to store: cannot be reversed to the full key
  prefix     String
  projectId  String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([projectId])
  @@map("ApiKey")
}

// ─── Bug capture models ───────────────────────────────────────────────────────

model Bug {
  id                String      @id @default(cuid())
  projectId         String
  status            BugStatus   @default(OPEN)
  pageUrl           String
  pageTitle         String?
  userAgent         String
  screenWidth       Int
  screenHeight      Int
  viewportWidth     Int?
  viewportHeight    Int?
  rrwebEvents       Json
  consoleLogs       Json
  networkFails      Json
  screenshotDataUrl String?     @db.Text
  playwrightScript  String?     @db.Text
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  report            BugReport?
  messages          BugMessage[]
  capturedAt        DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([projectId])
  @@index([projectId, capturedAt])
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  FIXED
  CLOSED
  DUPLICATE
}

model BugReport {
  id                 String   @id @default(cuid())
  bugId              String   @unique
  title              String
  summary            String   @db.Text
  stepsToReproduce   Json
  expectedBehaviour  String   @db.Text
  actualBehaviour    String   @db.Text
  suspectedCause     String?  @db.Text
  severity           String
  bug                Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)
  generatedAt        DateTime @default(now())
}

model BugMessage {
  id        String      @id @default(cuid())
  bugId     String
  role      MessageRole
  content   String      @db.Text
  bug       Bug         @relation(fields: [bugId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([bugId])
}

enum MessageRole {
  USER
  ASSISTANT
}

// ─── Session recording models ─────────────────────────────────────────────────

model Session {
  id              String           @id @default(cuid())
  projectId       String
  url             String
  userAgent       String
  screenWidth     Int
  screenHeight    Int
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events          SessionEvent[]
  consoleLogs     ConsoleLog[]
  networkRequests NetworkRequest[]
  startedAt       DateTime         @default(now())
  // Updated with each ingest chunk — used to detect stale/closed sessions
  lastEventAt     DateTime         @default(now())

  @@index([projectId])
  @@index([projectId, startedAt])
}

model SessionEvent {
  id        String  @id @default(cuid())
  sessionId String
  type      Int
  data      Json
  // BigInt: rrweb timestamps are ms since epoch — exceeds Int32 range
  timestamp BigInt
  // Chunk sequence number — used to reassemble events in order
  sequence  Int
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sequence])
}

model ConsoleLog {
  id        String   @id @default(cuid())
  sessionId String
  level     LogLevel
  message   String
  stack     String?
  timestamp BigInt
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum LogLevel {
  ERROR
  WARN
}

model NetworkRequest {
  id           String  @id @default(cuid())
  sessionId    String
  url          String
  method       String
  status       Int
  duration     Int
  timestamp    BigInt
  requestBody  String?
  responseBody String?
  session      Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  // Enables fast "show me all 500s in this session" queries
  @@index([sessionId, status])
}
